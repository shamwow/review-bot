# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Provider selection
LLM_PROVIDER=claude

# Claude authentication (only needed when LLM_PROVIDER=claude):
#   Option 1: API key
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   Option 2: run `claude login` first, then leave ANTHROPIC_API_KEY unset

# Codex authentication (only needed when LLM_PROVIDER=codex):
#   Option 1: API key
# CODEX_API_KEY=your_openai_key_here
#   Option 2: run `codex login` first, then leave CODEX_API_KEY unset

# Optional (defaults shown)
CLAUDE_MODEL=claude-opus-4-6
CODEX_MODEL=
MAX_REVIEW_TURNS=30
POLL_INTERVAL_MS=60000
REVIEW_TIMEOUT_MS=600000
WORK_DIR=/tmp/review-bot
TRANSCRIPT_DIR=/tmp/review-bot/transcripts
MAX_WRITE_TURNS=50
WRITE_TIMEOUT_MS=900000
MAX_REVIEW_CYCLES=5
CI_POLL_TIMEOUT_MS=600000
MERGE_CONFLICT_TIMEOUT_MS=300000
LOG_LEVEL=info
